---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI-curated research, automatically maintained' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <style>
    :root {
      --bg: #0d1117;
      --bg-surface: #161b22;
      --border: #30363d;
      --text: #e6edf3;
      --text-muted: #8b949e;
      --accent: #58a6ff;
      --max-width: 1140px;
    }

    @media (prefers-color-scheme: light) {
      :root {
        --bg: #ffffff;
        --bg-surface: #f6f8fa;
        --border: #d0d7de;
        --text: #1f2328;
        --text-muted: #656d76;
        --accent: #0969da;
      }
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, sans-serif;
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    header {
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      padding: 2rem 1.5rem;
      text-align: center;
    }

    header h1 { font-size: clamp(1.5rem, 4vw, 2.5rem); font-weight: 700; margin-bottom: 0.4rem; }
    header p { color: var(--text-muted); }

    nav {
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      padding: 0 1.5rem;
      position: sticky;
      top: 0;
      z-index: 10;
      backdrop-filter: blur(8px);
    }

    nav ul {
      list-style: none;
      display: flex;
      max-width: var(--max-width);
      margin: 0 auto;
      overflow-x: auto;
    }

    nav a {
      display: block;
      padding: 0.75rem 1rem;
      color: var(--text-muted);
      font-size: 0.875rem;
      white-space: nowrap;
      border-bottom: 2px solid transparent;
    }

    nav a:hover, nav a[aria-current] {
      color: var(--text);
      border-bottom-color: var(--accent);
      text-decoration: none;
    }

    main {
      flex: 1;
      max-width: var(--max-width);
      width: 100%;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    footer {
      background: var(--bg-surface);
      border-top: 1px solid var(--border);
      padding: 1.5rem;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    /* ── Reusable components ── */

    .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 1rem;
      border-left: 3px solid var(--accent);
      padding-left: 0.75rem;
    }

    .topic-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .topic-card {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem;
      transition: border-color 0.15s;
      color: inherit;
      display: block;
    }

    .topic-card:hover { border-color: var(--accent); text-decoration: none; }
    .topic-card h3 { margin-bottom: 0.5rem; font-size: 1rem; }
    .topic-card p { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1rem; }
    .topic-card .meta { font-size: 0.75rem; color: var(--text-muted); }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
      margin: 1rem 0;
    }

    th, td {
      padding: 0.625rem 0.875rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    th {
      background: var(--bg-surface);
      font-weight: 600;
      color: var(--text-muted);
      cursor: pointer;
      user-select: none;
    }

    th:hover { color: var(--text); }
    tr:hover td { background: var(--bg-surface); }

    @media (max-width: 600px) {
      main { padding: 1rem; }
      .topic-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <header>
    <h1><a href={base || '/'}>{title}</a></h1>
    <p>{description}</p>
  </header>

  <nav>
    <ul>
      <li><a href={base || '/'}>Home</a></li>
      <!-- The agent adds topic nav links here as topics are created -->
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <p>Research compiled from public sources by an AI agent. Always verify with primary sources.</p>
  </footer>
</body>
</html>
